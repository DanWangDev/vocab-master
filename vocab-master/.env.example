# Vocab Master Environment Configuration
# Copy this file to .env and fill in your values

# Vite API URL for frontend
VITE_API_URL=http://localhost:9876/api

# JWT Secret - REQUIRED: Generate a secure random string (at least 32 characters)
# Example: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-here-change-this

# Frontend port (default: 8080)
FRONTEND_PORT=8080

# Backend port (default: 9876)
BACKEND_PORT=9876

# CORS origin - URL of your frontend (for production)
# Include the protocol and port if not 80/443
# Example: https://vocab.yourdomain.com
CORS_ORIGIN=http://localhost:8080

# Email Service (Resend) - Required for password reset emails
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxx

# From address for emails (must match verified domain in Resend)
# Format: "Display Name <email@yourdomain.com>"
EMAIL_FROM=Vocabulary Master <noreply@yourdomain.com>

# Frontend URL (used for password reset links)
FRONTEND_URL=http://localhost:8080

# Admin setup
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-password

# Google OAuth - Get credentials from https://console.cloud.google.com
GOOGLE_CLIENT_ID_WEB=your-google-client-id.apps.googleusercontent.com
#GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
#GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-google-client-id.apps.googleusercontent.com
#EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
#EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# Cloudflare Turnstile - Bot protection (optional, skipped if not set)
# Get keys from https://dash.cloudflare.com > Turnstile
# Test keys below always pass (for development):
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
